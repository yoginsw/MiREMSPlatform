{
  "name": "mirems-frontend",
  "version": "0.1.0-SNAPSHOT",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "e2e:list": "pnpm --filter @mirems/e2e e2e:list",
    "e2e": "pnpm --filter @mirems/e2e e2e",
    "load:smoke": "pnpm --filter @mirems/e2e load:smoke",
    "load:10k": "pnpm --filter @mirems/e2e load:10k",
    "chaos:smoke": "pnpm --filter @mirems/e2e chaos:smoke"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.9.0",
    "vitest": "^2.1.9"
  }
}
