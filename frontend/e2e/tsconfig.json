{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "types": ["node", "vitest/globals", "@playwright/test"]
  },
  "include": ["*.ts", "tests/**/*.ts", "fixtures/**/*.ts", "src/**/*.ts"]
}
