# MiREMS local development environment template.
# Copy to infrastructure/docker/.env before running `make dev-up`.

# Application-facing environment variables from AGENTS.md §7
MIREMS_DB_URL=jdbc:postgresql://localhost:15432/mirems
MIREMS_DB_USER=mirems
MIREMS_DB_PASS=mirems_dev_password
MIREMS_KEYCLOAK_URL=http://localhost:8081
MIREMS_KEYCLOAK_REALM=mirems
MIREMS_KEYCLOAK_CLIENT=mirems-frontend
MIREMS_KAFKA_BOOTSTRAP=localhost:9094
# Development-only sample key. Replace for any shared/non-local environment.
MIREMS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Docker Compose service configuration
MIREMS_DB_NAME=mirems
MIREMS_KEYCLOAK_DB_NAME=keycloak
MIREMS_DB_PORT=15432
MIREMS_KEYCLOAK_PORT=8081
MIREMS_KEYCLOAK_ADMIN=admin
MIREMS_KEYCLOAK_ADMIN_PASSWORD=admin
MIREMS_KAFKA_EXTERNAL_PORT=9094
MIREMS_KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
MIREMS_KAFKA_UI_PORT=8082
MIREMS_KOGITO_CONSOLE_PORT=8280
MIREMS_KOGITO_DATAINDEX_URL=http://localhost:8180
