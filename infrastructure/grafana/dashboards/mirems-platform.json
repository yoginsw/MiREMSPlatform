{
  "title": "MiREMS Platform Production Overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": [
    "mirems",
    "vvsg",
    "election"
  ],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"mirems-core-api\"}[5m])) by (uri,method,status)",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API latency p95",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"mirems-core-api\"}[5m])) by (le,uri))",
          "legendFormat": "{{uri}} p95"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Audit events by type",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(mirems_audit_events_total[1h])) by (event_type)",
          "legendFormat": "{{event_type}}"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 8
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Voting sessions opened",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(mirems_voting_sessions_opened_total[1h]))",
          "legendFormat": "opened"
        }
      ],
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 8
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM memory used",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"mirems-core-api\"}) by (area)",
          "legendFormat": "{{area}}"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 8
      }
    }
  ]
}
