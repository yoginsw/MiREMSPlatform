<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="Definitions_UsVoterEligibility"
             name="UsVoterEligibility"
             namespace="https://mirems.io/dmn/us/voter-eligibility">
    <inputData id="Input_citizenshipStatus" name="citizenshipStatus"><variable id="Variable_citizenshipStatus" name="citizenshipStatus" typeRef="string"/></inputData>
    <inputData id="Input_birthDate" name="birthDate"><variable id="Variable_birthDate" name="birthDate" typeRef="date"/></inputData>
    <inputData id="Input_electionDay" name="electionDay"><variable id="Variable_electionDay" name="electionDay" typeRef="date"/></inputData>
    <inputData id="Input_generalElectionDay" name="generalElectionDay"><variable id="Variable_generalElectionDay" name="generalElectionDay" typeRef="date"/></inputData>
    <inputData id="Input_electionType" name="electionType"><variable id="Variable_electionType" name="electionType" typeRef="string"/></inputData>
    <inputData id="Input_stateCode" name="stateCode"><variable id="Variable_stateCode" name="stateCode" typeRef="string"/></inputData>
    <inputData id="Input_idVerificationStatus" name="idVerificationStatus"><variable id="Variable_idVerificationStatus" name="idVerificationStatus" typeRef="string"/></inputData>
    <inputData id="Input_registered" name="registered"><variable id="Variable_registered" name="registered" typeRef="boolean"/></inputData>
    <decision id="Decision_UsVoterEligibility" name="UsVoterEligibility">
        <variable id="Variable_result" name="voterEligibility" typeRef="UsVoterEligibilityResult"/>
        <decisionTable id="DecisionTable_UsVoterEligibility" hitPolicy="FIRST" preferredOrientation="Rule-as-Row">
            <input id="InputClause_citizenshipStatus"><inputExpression id="InputExpression_citizenshipStatus" typeRef="string"><text>citizenshipStatus</text></inputExpression></input>
            <input id="InputClause_registered"><inputExpression id="InputExpression_registered" typeRef="boolean"><text>registered</text></inputExpression></input>
            <input id="InputClause_ageOnElectionDay"><inputExpression id="InputExpression_ageOnElectionDay" typeRef="number"><text>years and months duration(birthDate, electionDay).years</text></inputExpression></input>
            <input id="InputClause_electionType"><inputExpression id="InputExpression_electionType" typeRef="string"><text>electionType</text></inputExpression></input>
            <input id="InputClause_stateCode"><inputExpression id="InputExpression_stateCode" typeRef="string"><text>upper case(string(stateCode))</text></inputExpression></input>
            <input id="InputClause_ageOnGeneralElectionDay"><inputExpression id="InputExpression_ageOnGeneralElectionDay" typeRef="number"><text>years and months duration(birthDate, generalElectionDay).years</text></inputExpression></input>
            <input id="InputClause_idVerificationStatus"><inputExpression id="InputExpression_idVerificationStatus" typeRef="string"><text>idVerificationStatus</text></inputExpression></input>
            <output id="OutputClause_eligible" label="eligible" name="eligible" typeRef="boolean"/>
            <output id="OutputClause_provisional" label="provisionalBallotRequired" name="provisionalBallotRequired" typeRef="boolean"/>
            <output id="OutputClause_reason" label="reason" name="reason" typeRef="string"/>
            <rule id="Rule_NonCitizen"><inputEntry id="R1_C"><text>not("CITIZEN")</text></inputEntry><inputEntry id="R1_R"><text>-</text></inputEntry><inputEntry id="R1_A"><text>-</text></inputEntry><inputEntry id="R1_T"><text>-</text></inputEntry><inputEntry id="R1_S"><text>-</text></inputEntry><inputEntry id="R1_G"><text>-</text></inputEntry><inputEntry id="R1_I"><text>-</text></inputEntry><outputEntry id="R1_O1"><text>false</text></outputEntry><outputEntry id="R1_O2"><text>false</text></outputEntry><outputEntry id="R1_O3"><text>"US federal elections require citizenship"</text></outputEntry></rule>
            <rule id="Rule_Unregistered"><inputEntry id="R2_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R2_R"><text>false</text></inputEntry><inputEntry id="R2_A"><text>-</text></inputEntry><inputEntry id="R2_T"><text>-</text></inputEntry><inputEntry id="R2_S"><text>-</text></inputEntry><inputEntry id="R2_G"><text>-</text></inputEntry><inputEntry id="R2_I"><text>-</text></inputEntry><outputEntry id="R2_O1"><text>false</text></outputEntry><outputEntry id="R2_O2"><text>false</text></outputEntry><outputEntry id="R2_O3"><text>"voter registration is required"</text></outputEntry></rule>
            <rule id="Rule_UnderAgeGeneral"><inputEntry id="R3_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R3_R"><text>true</text></inputEntry><inputEntry id="R3_A"><text>&lt; 18</text></inputEntry><inputEntry id="R3_T"><text>"GENERAL_ELECTION"</text></inputEntry><inputEntry id="R3_S"><text>-</text></inputEntry><inputEntry id="R3_G"><text>-</text></inputEntry><inputEntry id="R3_I"><text>-</text></inputEntry><outputEntry id="R3_O1"><text>false</text></outputEntry><outputEntry id="R3_O2"><text>false</text></outputEntry><outputEntry id="R3_O3"><text>"voter must be 18 on election day"</text></outputEntry></rule>
            <rule id="Rule_UnderAgePrimaryStandard"><inputEntry id="R4_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R4_R"><text>true</text></inputEntry><inputEntry id="R4_A"><text>&lt; 18</text></inputEntry><inputEntry id="R4_T"><text>"PRIMARY_ELECTION"</text></inputEntry><inputEntry id="R4_S"><text>not("MD")</text></inputEntry><inputEntry id="R4_G"><text>-</text></inputEntry><inputEntry id="R4_I"><text>-</text></inputEntry><outputEntry id="R4_O1"><text>false</text></outputEntry><outputEntry id="R4_O2"><text>false</text></outputEntry><outputEntry id="R4_O3"><text>"voter must be 18 on primary election day"</text></outputEntry></rule>
            <rule id="Rule_PrimaryAgeByGeneralHavaProvisional"><inputEntry id="R5H_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R5H_R"><text>true</text></inputEntry><inputEntry id="R5H_A"><text>&lt; 18</text></inputEntry><inputEntry id="R5H_T"><text>"PRIMARY_ELECTION"</text></inputEntry><inputEntry id="R5H_S"><text>"MD"</text></inputEntry><inputEntry id="R5H_G"><text>&gt;= 18</text></inputEntry><inputEntry id="R5H_I"><text>"UNVERIFIED_HAVA_ID"</text></inputEntry><outputEntry id="R5H_O1"><text>true</text></outputEntry><outputEntry id="R5H_O2"><text>true</text></outputEntry><outputEntry id="R5H_O3"><text>"HAVA ID verification requires provisional ballot"</text></outputEntry></rule>
            <rule id="Rule_PrimaryAgeByGeneralElection"><inputEntry id="R5_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R5_R"><text>true</text></inputEntry><inputEntry id="R5_A"><text>&lt; 18</text></inputEntry><inputEntry id="R5_T"><text>"PRIMARY_ELECTION"</text></inputEntry><inputEntry id="R5_S"><text>"MD"</text></inputEntry><inputEntry id="R5_G"><text>&gt;= 18</text></inputEntry><inputEntry id="R5_I"><text>"VERIFIED"</text></inputEntry><outputEntry id="R5_O1"><text>true</text></outputEntry><outputEntry id="R5_O2"><text>false</text></outputEntry><outputEntry id="R5_O3"><text>"eligible primary voter turning 18 by general election"</text></outputEntry></rule>
            <rule id="Rule_HavaProvisional"><inputEntry id="R6_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R6_R"><text>true</text></inputEntry><inputEntry id="R6_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R6_T"><text>-</text></inputEntry><inputEntry id="R6_S"><text>-</text></inputEntry><inputEntry id="R6_G"><text>-</text></inputEntry><inputEntry id="R6_I"><text>"UNVERIFIED_HAVA_ID"</text></inputEntry><outputEntry id="R6_O1"><text>true</text></outputEntry><outputEntry id="R6_O2"><text>true</text></outputEntry><outputEntry id="R6_O3"><text>"HAVA ID verification requires provisional ballot"</text></outputEntry></rule>
            <rule id="Rule_VerifiedEligible"><inputEntry id="R7_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R7_R"><text>true</text></inputEntry><inputEntry id="R7_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R7_T"><text>-</text></inputEntry><inputEntry id="R7_S"><text>-</text></inputEntry><inputEntry id="R7_G"><text>-</text></inputEntry><inputEntry id="R7_I"><text>"VERIFIED"</text></inputEntry><outputEntry id="R7_O1"><text>true</text></outputEntry><outputEntry id="R7_O2"><text>false</text></outputEntry><outputEntry id="R7_O3"><text>"eligible verified voter"</text></outputEntry></rule>
        </decisionTable>
    </decision>
</definitions>
