<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="Definitions_KrVoterEligibility"
             name="KrVoterEligibility"
             namespace="https://mirems.io/dmn/kr/voter-eligibility">
    <inputData id="Input_voterAge" name="voterAge"><variable id="Variable_voterAge" name="voterAge" typeRef="number"/></inputData>
    <inputData id="Input_citizenship" name="citizenship"><variable id="Variable_citizenship" name="citizenship" typeRef="string"/></inputData>
    <inputData id="Input_permanentResident" name="permanentResident"><variable id="Variable_permanentResident" name="permanentResident" typeRef="boolean"/></inputData>
    <inputData id="Input_electionType" name="electionType"><variable id="Variable_electionType" name="electionType" typeRef="string"/></inputData>
    <decision id="Decision_KrVoterEligibility" name="KrVoterEligibility">
        <variable id="Variable_result" name="voterEligibility" typeRef="KrVoterEligibilityResult"/>
        <decisionTable id="DecisionTable_KrVoterEligibility" hitPolicy="FIRST" preferredOrientation="Rule-as-Row">
            <input id="InputClause_voterAge"><inputExpression id="InputExpression_voterAge" typeRef="number"><text>voterAge</text></inputExpression></input>
            <input id="InputClause_citizenship"><inputExpression id="InputExpression_citizenship" typeRef="string"><text>citizenship</text></inputExpression></input>
            <input id="InputClause_permanentResident"><inputExpression id="InputExpression_permanentResident" typeRef="boolean"><text>permanentResident</text></inputExpression></input>
            <input id="InputClause_electionType"><inputExpression id="InputExpression_electionType" typeRef="string"><text>electionType</text></inputExpression></input>
            <output id="OutputClause_eligible" label="eligible" name="eligible" typeRef="boolean"/>
            <output id="OutputClause_reason" label="reason" name="reason" typeRef="string"/>
            <rule id="Rule_UnderAge"><inputEntry id="R1_A"><text>&lt; 18</text></inputEntry><inputEntry id="R1_C"><text>-</text></inputEntry><inputEntry id="R1_P"><text>-</text></inputEntry><inputEntry id="R1_T"><text>-</text></inputEntry><outputEntry id="R1_O1"><text>false</text></outputEntry><outputEntry id="R1_O2"><text>"voter age must be at least 18"</text></outputEntry></rule>
            <rule id="Rule_CitizenPresidential"><inputEntry id="R2_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R2_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R2_P"><text>-</text></inputEntry><inputEntry id="R2_T"><text>"PRESIDENTIAL_ELECTION"</text></inputEntry><outputEntry id="R2_O1"><text>true</text></outputEntry><outputEntry id="R2_O2"><text>"eligible Korean citizen voter"</text></outputEntry></rule>
            <rule id="Rule_CitizenNationalAssembly"><inputEntry id="R3_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R3_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R3_P"><text>-</text></inputEntry><inputEntry id="R3_T"><text>"NATIONAL_ASSEMBLY_ELECTION"</text></inputEntry><outputEntry id="R3_O1"><text>true</text></outputEntry><outputEntry id="R3_O2"><text>"eligible Korean citizen voter"</text></outputEntry></rule>
            <rule id="Rule_CitizenLocal"><inputEntry id="R4_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R4_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R4_P"><text>-</text></inputEntry><inputEntry id="R4_T"><text>"LOCAL_ELECTION"</text></inputEntry><outputEntry id="R4_O1"><text>true</text></outputEntry><outputEntry id="R4_O2"><text>"eligible Korean citizen voter"</text></outputEntry></rule>
            <rule id="Rule_CitizenSuperintendent"><inputEntry id="R5_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R5_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R5_P"><text>-</text></inputEntry><inputEntry id="R5_T"><text>"SUPERINTENDENT_ELECTION"</text></inputEntry><outputEntry id="R5_O1"><text>true</text></outputEntry><outputEntry id="R5_O2"><text>"eligible Korean citizen voter"</text></outputEntry></rule>
            <rule id="Rule_CitizenByElection"><inputEntry id="R6_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R6_C"><text>"CITIZEN"</text></inputEntry><inputEntry id="R6_P"><text>-</text></inputEntry><inputEntry id="R6_T"><text>"BY_ELECTION"</text></inputEntry><outputEntry id="R6_O1"><text>true</text></outputEntry><outputEntry id="R6_O2"><text>"eligible Korean citizen voter"</text></outputEntry></rule>
            <rule id="Rule_PermanentResidentLocal"><inputEntry id="R7_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R7_C"><text>"FOREIGN_PERMANENT_RESIDENT"</text></inputEntry><inputEntry id="R7_P"><text>true</text></inputEntry><inputEntry id="R7_T"><text>"LOCAL_ELECTION"</text></inputEntry><outputEntry id="R7_O1"><text>true</text></outputEntry><outputEntry id="R7_O2"><text>"eligible permanent resident local voter"</text></outputEntry></rule>
            <rule id="Rule_PermanentResidentSuperintendent"><inputEntry id="R8_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R8_C"><text>"FOREIGN_PERMANENT_RESIDENT"</text></inputEntry><inputEntry id="R8_P"><text>true</text></inputEntry><inputEntry id="R8_T"><text>"SUPERINTENDENT_ELECTION"</text></inputEntry><outputEntry id="R8_O1"><text>true</text></outputEntry><outputEntry id="R8_O2"><text>"eligible permanent resident local voter"</text></outputEntry></rule>
            <rule id="Rule_LocalRequiresCitizenOrPermanentResident"><inputEntry id="R9_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R9_C"><text>not("CITIZEN")</text></inputEntry><inputEntry id="R9_P"><text>-</text></inputEntry><inputEntry id="R9_T"><text>"LOCAL_ELECTION", "SUPERINTENDENT_ELECTION"</text></inputEntry><outputEntry id="R9_O1"><text>false</text></outputEntry><outputEntry id="R9_O2"><text>"local elections require Korean citizenship or permanent resident status"</text></outputEntry></rule>
            <rule id="Rule_NationalRequiresCitizenship"><inputEntry id="R10_A"><text>&gt;= 18</text></inputEntry><inputEntry id="R10_C"><text>not("CITIZEN")</text></inputEntry><inputEntry id="R10_P"><text>-</text></inputEntry><inputEntry id="R10_T"><text>"PRESIDENTIAL_ELECTION", "NATIONAL_ASSEMBLY_ELECTION", "BY_ELECTION"</text></inputEntry><outputEntry id="R10_O1"><text>false</text></outputEntry><outputEntry id="R10_O2"><text>"national elections require Korean citizenship"</text></outputEntry></rule>
        </decisionTable>
    </decision>
</definitions>
