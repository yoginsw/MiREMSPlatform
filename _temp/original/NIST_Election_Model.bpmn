            <outgoing>_18_5_3_43701b0_1516656409155_147017_41167</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Overlay districts" id="_18_5_3_43701b0_1516656409131_828070_41158">
            <documentation textFormat="text/plain">Overlay all the districts that are relevant for voting purposes.</documentation>
            <incoming>_18_5_3_43701b0_1516656409155_147017_41167</incoming>
            <outgoing>_18_5_3_43701b0_1516656703421_222384_41199</outgoing>
