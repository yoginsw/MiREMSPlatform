    <process isClosed="false" isExecutable="false" name="Determine Precinct-Splits" id="_18_5_3_43701b0_1516656356105_497289_41072">
        <documentation textFormat="text/plain">Determine the smallest voting units (aka precinct-splits) that exist in a given jurisdiction.</documentation>
        <laneSet id="_18_5_3_43701b0_1516656356105_497289_41072_laneSet">
            <lane name="Election Jurisdiction" id="_18_5_3_43701b0_1516656378434_550603_41125">
