            <incoming>_18_5_1_11940316_1501694926896_85170_26200</incoming>
        </endEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Index ballot package as required" id="_18_5_1_11940316_1501694989954_124283_26221">
            <documentation textFormat="text/plain">Index the ballot package so that it can be counted in its appropriate batch.</documentation>
