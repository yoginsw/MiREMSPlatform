        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Break down and pack up voting equipment and materials" id="_18_5_1_11940316_1500556786241_620648_33415">
            <documentation textFormat="text/plain">Some break down may be done after Election Day. However, break down that may occur on Election Day includes the shutdown and sealing of equipment, removal of forms and envelops, and other activities that return the voting location to its prior state.</documentation>
            <incoming>_18_5_1_11940316_1500556786297_278245_33424</incoming>
