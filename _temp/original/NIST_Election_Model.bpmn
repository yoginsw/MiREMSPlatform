    <process isClosed="false" isExecutable="false" name="Publish Sample Ballots" id="_18_5_1_11940316_1500468929540_480782_24625">
        <documentation textFormat="text/plain">Publish sample ballots containing the contests and selections to be voted on.</documentation>
        <laneSet id="_18_5_1_11940316_1500468929540_480782_24625_laneSet">
            <lane name="Election Jurisdiction" id="_18_5_1_11940316_1502912176528_293239_27296">
                <flowNodeRef>_18_5_1_11940316_1502912194601_531390_27309</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1502912720113_686824_27510</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1502913316674_983604_27675</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1502969424089_993372_27407</flowNodeRef>
            </lane>
        </laneSet>
        <startEvent isInterrupting="true" name="" id="_18_5_1_11940316_1502912194601_531390_27309">
            <outgoing>_18_5_1_11940316_1502912348302_925146_27366</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Produce sample ballot" id="_18_5_1_11940316_1502912720113_686824_27510">
            <documentation textFormat="text/plain">Produce a sample ballot. At a minimum a sample ballot should contain the contests and candidates that will appear on the official ballot. A higher fidelity sample ballot will take the form of an official ballot with some of the features that make it countable removed.</documentation>
            <incoming>_18_5_1_11940316_1502912348302_925146_27366</incoming>
            <incoming>_18_5_1_11940316_1502912911933_197290_27560</incoming>
            <outgoing>_18_5_1_11940316_1502913438259_976898_27713</outgoing>
        </task>
        <dataObjectReference name="Presentable Ballot Styles" id="_18_5_1_11940316_1502912896431_681895_27536">
            <outgoing>_18_5_1_11940316_1502912911933_197290_27560</outgoing>
        </dataObjectReference>
        <subProcess triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Publish Sample Ballots" id="_18_5_1_11940316_1502913316674_983604_27675">
            <documentation textFormat="text/plain">Publish the sample ballot over multiple channels.</documentation>
            <incoming>_18_5_1_11940316_1502913438259_976898_27713</incoming>
            <outgoing>_18_5_1_11940316_1502969424133_225734_27411</outgoing>
        </subProcess>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Publish to website" id="_18_5_1_11940316_1502913038269_358784_27569">
            <documentation textFormat="text/plain">Publish sample ballots to election authority's website.</documentation>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Publish to media" id="_18_5_1_11940316_1502913063453_976058_27599">
            <documentation textFormat="text/plain">Provide sample ballots to the media for general distribution.</documentation>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Print for distribution" id="_18_5_1_11940316_1502913073966_520208_27630">
            <documentation textFormat="text/plain">Print sample ballots for distribution to interested parties.</documentation>
        </task>
        <endEvent name="Sample Ballots Published" id="_18_5_1_11940316_1502969424089_993372_27407">
            <incoming>_18_5_1_11940316_1502969424133_225734_27411</incoming>
        </endEvent>
