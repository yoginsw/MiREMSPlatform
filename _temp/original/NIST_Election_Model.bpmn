                <flowNodeRef>_18_5_2_11940316_1504022014511_840561_30454</flowNodeRef>
            </lane>
        </laneSet>
        <startEvent isInterrupting="true" name="Time to Define Statutory Election" id="_18_5_2_11940316_1504018568879_121143_29198">
            <outgoing>_18_5_2_11940316_1504018867220_912388_29288</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Identify contests that may be voted upon" id="_18_5_2_11940316_1504018762531_678956_29247">
            <documentation textFormat="text/plain">Identify the contests that may appear on the ballot of an upcoming election. This is determined by a range of factors, including the terms of office, the number of office seats, partisan status, etc.</documentation>
            <incoming>_18_5_2_11940316_1504018867220_912388_29288</incoming>
            <incoming>_18_5_2_11940316_1504026880842_768074_30629</incoming>
            <incoming>_18_5_2_11940316_1506375707568_546390_43416</incoming>
            <outgoing>_18_5_2_11940316_1504183022120_361000_43302</outgoing>
            <outgoing>_18_5_2_11940316_1504184601833_117075_43412</outgoing>
        </task>
        <startEvent isInterrupting="true" name="Other Trigger" id="_18_5_2_11940316_1504018775301_170646_29272">
            <documentation textFormat="text/plain">Vacancy, Act of assembly, citizen initiative, recall attempt</documentation>
            <outgoing>_18_5_2_11940316_1504026880842_768074_30629</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Publish requirements" id="_18_5_2_11940316_1504027048510_475077_30647">
            <documentation textFormat="text/plain">Make the requirements for filing available to interested parties.</documentation>
            <incoming>_18_5_2_11940316_1504184605333_330662_43421</incoming>
            <incoming>_18_5_2_11940316_1504185054610_821192_43513</incoming>
            <outgoing>_18_5_2_11940316_1504028548091_775507_30686</outgoing>
        </task>
        <endEvent name="Contests Identified" id="_18_5_2_11940316_1504028548059_431460_30682">
            <incoming>_18_5_2_11940316_1504028548091_775507_30686</incoming>
        </endEvent>
        <dataObjectReference name="List of Contests" id="_18_5_2_11940316_1504182991464_205499_43252">
            <incoming>_18_5_2_11940316_1504183022120_361000_43302</incoming>
            <outgoing>_18_5_2_11940316_1504183039846_875182_43311</outgoing>
        </dataObjectReference>
        <subProcess triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Gather requirements" id="_18_5_2_11940316_1504184452855_471080_43363">
            <documentation textFormat="text/plain">Gather requirements for a candidate or issue to appear on the ballot. These requirements may come from federal, state and local law.</documentation>
            <incoming>_18_5_2_11940316_1504183039846_875182_43311</incoming>
            <incoming>_18_5_2_11940316_1504184601833_117075_43412</incoming>
            <outgoing>_18_5_2_11940316_1504184605333_330662_43421</outgoing>
            <outgoing>_18_5_2_11940316_1504185049651_374114_43504</outgoing>
        </subProcess>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Calculate variable requirements" id="_18_5_2_11940316_1504018983906_447387_29312">
            <documentation textFormat="text/plain">Calculate the requirements that are defined by formula, such as a filing fee based on salary, or a minimum number of valid signatures based on past turnout.</documentation>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Gather fixed requirements" id="_18_5_2_11940316_1504022014511_840561_30454">
            <documentation textFormat="text/plain">Gather the requirements that do not change based on external factors. These may include age, residency requirements, and a filing fee, if it is fixed.</documentation>
        </task>
        <dataObjectReference name="List of Contest Requirements" id="_18_5_2_11940316_1504185000021_951446_43478">
            <incoming>_18_5_2_11940316_1504185049651_374114_43504</incoming>
            <outgoing>_18_5_2_11940316_1504185054610_821192_43513</outgoing>
        </dataObjectReference>
