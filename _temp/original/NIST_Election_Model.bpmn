        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Create precinct-splits at intersections" id="_18_5_3_43701b0_1516656703402_210052_41190">
            <documentation textFormat="text/plain">Create a new precinct-split feature for the intersecting districts until no district crosses a precinct-split.  </documentation>
            <incoming>_18_5_3_43701b0_1516656703421_222384_41199</incoming>
            <outgoing>_18_5_3_43701b0_1517437958471_126661_30465</outgoing>
