            <outgoing>_18_5_1_11940316_1501694462127_568134_26024</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Determine eligibility to  be counted" id="_18_5_1_11940316_1501694462042_823241_26015">
            <documentation textFormat="text/plain">Determine whether the ballot can be counted. This may be based on a variety of factors, such as timeliness, completeness of the ballot package, and eligibility to vote.</documentation>
            <incoming>_18_5_1_11940316_1501694462127_568134_26024</incoming>
            <outgoing>_18_5_1_11940316_1501694518308_650054_26056</outgoing>
        </task>
        <exclusiveGateway name="Countability?" id="_18_5_1_11940316_1501694518251_170126_26047" gatewayDirection="Unspecified">
            <incoming>_18_5_1_11940316_1501694518308_650054_26056</incoming>
            <outgoing>_18_5_1_11940316_1501694544173_738576_26077</outgoing>
            <outgoing>_18_5_1_11940316_1501694765705_307883_26116</outgoing>
            <outgoing>_18_5_1_11940316_1501694839269_483129_26138</outgoing>
        </exclusiveGateway>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Contact voter to correct deficiency" id="_18_5_1_11940316_1501694544086_914833_26068">
            <documentation textFormat="text/plain">If the ballot package is deficient, the voter may be contacted to correct the deficiency. There is usually a limited time window for this correction to occur.</documentation>
            <incoming>_18_5_1_11940316_1501694544173_738576_26077</incoming>
            <outgoing>_18_5_1_11940316_1501694966938_411733_26212</outgoing>
        </task>
