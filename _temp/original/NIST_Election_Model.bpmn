        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Retrieve ballot samples per audit rules/standards" id="_18_5_1_11940316_1500583484424_690485_37800">
            <documentation textFormat="text/plain">The units to be audited, may be set by rule. They may include precincts, polling locations, machines, among others. </documentation>
            <incoming>_18_5_1_11940316_1500583484493_842221_37809</incoming>
            <incoming>_18_5_1_11940316_1500583763014_521263_38065</incoming>
            <incoming>_18_5_2_11940316_1506454340470_169030_49652</incoming>
            <outgoing>_18_5_1_11940316_1500583569549_352962_37839</outgoing>
        </task>
        <parallelGateway name="" id="_18_5_1_11940316_1500583569507_263944_37832" gatewayDirection="Unspecified">
            <incoming>_18_5_1_11940316_1500583569549_352962_37839</incoming>
            <outgoing>_18_5_1_11940316_1500583572607_26765_37861</outgoing>
            <outgoing>_18_5_1_11940316_1500583607013_56986_37917</outgoing>
        </parallelGateway>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Perform manual or machine vote recount" id="_18_5_1_11940316_1500583572531_481182_37851">
            <documentation textFormat="text/plain">Derive the summary totals from their source (e.g. voted paper ballots, or electronic media).</documentation>
            <incoming>_18_5_1_11940316_1500583572607_26765_37861</incoming>
            <incoming>_18_5_2_11940316_1506519577387_281899_49832</incoming>
            <outgoing>_18_5_1_11940316_1500583592407_234510_37889</outgoing>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Compare recount totals to contest results" id="_18_5_1_11940316_1500583592342_120520_37880">
            <documentation textFormat="text/plain">Compare the recounted totals to the original tally.</documentation>
            <incoming>_18_5_1_11940316_1500583592407_234510_37889</incoming>
            <outgoing>_18_5_1_11940316_1500583666000_592919_37955</outgoing>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Compare voter verified CVR to electronic CVR" id="_18_5_1_11940316_1500583606921_626431_37908">
            <documentation textFormat="text/plain">Where available, compare the voter verified cast vote record (e.g. VVPAT or ballot) against its electronic equivalent.</documentation>
            <incoming>_18_5_1_11940316_1500583607013_56986_37917</incoming>
            <incoming>_18_5_2_11940316_1506519662813_953961_49864</incoming>
