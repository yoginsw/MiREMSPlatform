            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Send notice" id="_18_5_1_11940316_1501785439048_180514_32921">
                <documentation textFormat="text/plain">Send a positive disposition notice. This notice may include such details as the voter’s polling location, voting districts, and voter identification requirements.</documentation>
                <incoming>_18_5_1_11940316_1501859251266_413941_26341</incoming>
                <outgoing>_18_5_1_11940316_1499538193301_838395_25935</outgoing>
