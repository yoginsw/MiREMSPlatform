            <multiInstanceLoopCharacteristics isSequential="false" behavior="All" id="_18_5_1_11940316_1502385374226_704371_38499_Ref-1"/>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Select contests by ballot style" id="_18_5_1_11940316_1499869439797_686060_23256">
                <documentation textFormat="text/plain">Select the contests appearing on this ballot style.</documentation>
                <incoming>_18_5_1_11940316_1499869439860_131292_23265</incoming>
                <outgoing>_18_5_1_11940316_1499869462052_796081_23308</outgoing>
                <resourceRole name="" id="_18_5_1_11940316_1499869646570_282407_23499_Ref-2"/>
            </task>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Order contests" id="_18_5_1_11940316_1499869461984_365275_23299">
                <documentation textFormat="text/plain">Put the contests in the relative order prescribed by law or policy.</documentation>
                <incoming>_18_5_1_11940316_1499869462052_796081_23308</incoming>
                <outgoing>_18_5_1_11940316_1499869472049_978854_23337</outgoing>
                <resourceRole name="" id="_18_5_1_11940316_1499869646570_282407_23499_Ref-3"/>
            </task>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Rotate candidates" id="_18_5_1_11940316_1499869560445_412730_23404">
                <documentation textFormat="text/plain">Reorder the candidates from their original ordering by a fixed offset.</documentation>
                <incoming>_18_5_1_11940316_1499869560528_372229_23414</incoming>
                <outgoing>_18_5_1_11940316_1499869577840_631423_23431</outgoing>
                <resourceRole name="" id="_18_5_1_11940316_1499869646570_282407_23499_Ref-4"/>
            </task>
            <exclusiveGateway gatewayDirection="Unspecified" name="Candidate rotation required?" id="_18_5_1_11940316_1499869483485_182713_23354">
                <incoming>_18_5_1_11940316_1499869483527_554395_23363</incoming>
                <outgoing>_18_5_1_11940316_1499869512230_869816_23384</outgoing>
                <outgoing>_18_5_1_11940316_1499869560528_372229_23414</outgoing>
            </exclusiveGateway>
            <startEvent name="" id="_18_5_1_11940316_1499869420907_223277_23240">
                <outgoing>_18_5_1_11940316_1499869439860_131292_23265</outgoing>
            </startEvent>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Order candidates" id="_18_5_1_11940316_1499869471947_762327_23328">
                <documentation textFormat="text/plain">Order the candidates within a contest (e.g. alphabetically, by name, party, etc.).</documentation>
                <incoming>_18_5_1_11940316_1499869472049_978854_23337</incoming>
                <outgoing>_18_5_1_11940316_1499869483527_554395_23363</outgoing>
                <resourceRole name="" id="_18_5_1_11940316_1499869646570_282407_23499_Ref-5"/>
            </task>
            <endEvent name="" id="_18_5_1_11940316_1499869583747_895851_23440">
                <incoming>_18_5_1_11940316_1499869583782_883353_23445</incoming>
            </endEvent>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Apply formatting" id="_18_5_1_11940316_1499869512160_211346_23375">
                <documentation textFormat="text/plain">Apply formatting to the ballot. This may include applying fonts, setting line widths, applying page and column break rules, colors, etc.</documentation>
                <incoming>_18_5_1_11940316_1499869512230_869816_23384</incoming>
                <incoming>_18_5_1_11940316_1499869577840_631423_23431</incoming>
                <outgoing>_18_5_1_11940316_1499869583782_883353_23445</outgoing>
