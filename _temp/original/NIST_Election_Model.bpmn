    <process isClosed="false" isExecutable="false" name="Identify Contests" id="_18_5_1_11940316_1500469579790_810513_24938">
        <documentation textFormat="text/plain">Identify the contests that may appear on an upcoming election's ballot.</documentation>
        <laneSet id="_18_5_1_11940316_1500469579790_810513_24938_laneSet">
            <lane name="Election Jurisdiction" id="_18_5_2_11940316_1504123056217_138447_36018">
                <flowNodeRef>_18_5_2_11940316_1504018568879_121143_29198</flowNodeRef>
                <flowNodeRef>_18_5_2_11940316_1504018762531_678956_29247</flowNodeRef>
                <flowNodeRef>_18_5_2_11940316_1504018775301_170646_29272</flowNodeRef>
