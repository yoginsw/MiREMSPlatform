    <process isClosed="false" isExecutable="false" name="NVRA General Program" id="_18_5_1_11940316_1499458815454_16555_25395">
        <documentation textFormat="text/plain">For each address update: Look up a record in the voter registration database, and confirm or update the voter’s address.</documentation>
