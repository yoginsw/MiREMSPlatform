            <outgoing>_18_5_2_43701b0_1512413893656_412779_31951</outgoing>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Remove from election specific eligible voter list" id="_18_5_2_43701b0_1512413784923_50679_31907">
