        </endEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Associate precinct-splits with districts and precinct" id="_18_5_3_43701b0_1517437956991_580292_30446">
            <documentation textFormat="text/plain">Associate the precinct-split with composing precincts and districts.</documentation>
            <incoming>_18_5_3_43701b0_1517437958471_126661_30465</incoming>
            <outgoing>_18_5_3_43701b0_1517440263581_775535_30844</outgoing>
