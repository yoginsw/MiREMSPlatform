    <process isClosed="false" isExecutable="false" name="Recruit Polling Locations" id="_18_5_1_11940316_1499867189394_949100_25741">
        <documentation textFormat="text/plain">Recruit locations that can serve as polling locations during the election. The criteria to recruit a polling location may include several factors, such as accessibility, parking, and proximity to the voters it will serve.</documentation>
    </process>
    <process isClosed="false" isExecutable="false" name="Recruit Poll Workers" id="_18_5_1_11940316_1499867198056_306352_25783">
        <documentation textFormat="text/plain">Recruit the poll workers who are required to conduct the election.</documentation>
    </process>
    <process isClosed="false" isExecutable="false" name="Lay Out Ballots" id="_18_5_1_11940316_1499869349020_730283_23152">
        <documentation textFormat="text/plain">For each ballot style: select the contests and selections to appear on the ballot and apply business rules determining their order and location.</documentation>
        <laneSet id="_18_5_1_11940316_1499869616230_506272_23460_Ref-1_laneSet">
            <lane name="Election Authority" partitionElementRef="_18_5_1_11940316_1498999818037_96552_21933" id="_18_5_1_11940316_1499869616230_506272_23460">
                <flowNodeRef>_18_5_1_11940316_1502385374226_704371_38499</flowNodeRef>
