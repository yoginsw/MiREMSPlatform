    <process isClosed="false" isExecutable="false" name="Receive and Process Ballot Packages" id="_18_5_1_11940316_1500467309814_661011_24185">
        <documentation textFormat="text/plain">Receive and process a ballot package, e.g. an absentee or provisional ballot.</documentation>
        <laneSet id="_18_5_1_11940316_1500467309814_661011_24185_laneSet">
            <lane name="Voter" id="_18_5_1_11940316_1501694356414_390961_25960">
