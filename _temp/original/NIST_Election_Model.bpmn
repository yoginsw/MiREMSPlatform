    <process isClosed="false" isExecutable="false" name="Maintain Chain of Custody" id="_19_0_2_43701b0_1561553656891_603699_25880">
        <documentation textFormat="text/plain">&lt;html&gt;
  &lt;head&gt;
		&lt;style&gt;
			p {padding:0px; margin:0px;}
		&lt;/style&gt;
	&lt;/head&gt;
  &lt;body&gt;
Whenever we start to care about it...&lt;/body&gt;
&lt;/html&gt;</documentation>
        <laneSet id="_19_0_2_43701b0_1561553656891_603699_25880_laneSet">
            <lane name="Authorized Personnel" id="_19_0_2_43701b0_1561553656928_65176_25913">
                <flowNodeRef>_19_0_2_43701b0_1561553656922_556606_25898</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656923_892155_25901</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656924_296032_25902</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656925_86123_25905</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656926_464428_25906</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656926_536236_25907</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656926_158422_25908</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656926_582788_25909</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656927_589428_25910</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561553656927_895199_25911</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561556356889_847140_25982</flowNodeRef>
                <flowNodeRef>_19_0_2_43701b0_1561571405548_916257_26350</flowNodeRef>
            </lane>
        </laneSet>
        <dataObjectReference name="Election Object" id="_19_0_2_43701b0_1561553656921_873703_25897">
            <incoming>_19_0_2_43701b0_1561569238087_566608_26092</incoming>
            <incoming>_19_0_2_43701b0_1561569250226_669960_26101</incoming>
        </dataObjectReference>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Take custody of object" id="_19_0_2_43701b0_1561553656922_556606_25898">
            <documentation textFormat="text/plain">Take custody of the object.</documentation>
            <incoming>_19_0_2_43701b0_1561553656929_92236_25918</incoming>
            <outgoing>_19_0_2_43701b0_1561553656929_411376_25919</outgoing>
            <outgoing>_19_0_2_43701b0_1561569250226_669960_26101</outgoing>
        </task>
        <dataObjectReference name="Chain of Custody Log" id="_19_0_2_43701b0_1561553656922_316251_25899">
            <incoming>_19_0_2_43701b0_1561553656930_496084_25927</incoming>
            <outgoing>_19_0_2_43701b0_1561553656931_301864_25932</outgoing>
        </dataObjectReference>
        <parallelGateway name="" id="_19_0_2_43701b0_1561553656922_906501_25900" gatewayDirection="Unspecified">
            <incoming>_19_0_2_43701b0_1561553656930_480031_25924</incoming>
            <incoming>_19_0_2_43701b0_1561553656930_550947_25925</incoming>
            <outgoing>_19_0_2_43701b0_1561553656928_404153_25915</outgoing>
            <outgoing>_19_0_2_43701b0_1561553656929_681711_25917</outgoing>
        </parallelGateway>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Record custody change" id="_19_0_2_43701b0_1561553656923_892155_25901">
            <documentation textFormat="text/plain">Record who is taking custody of the election object, from whom, and the time and location of the transfer. The transferee should note the condition of the artifact, or of the transport, if the artifact has been sealed. </documentation>
            <incoming>_19_0_2_43701b0_1561553656928_404153_25915</incoming>
            <incoming>_19_0_2_43701b0_1561569150397_474111_26073</incoming>
            <outgoing>_19_0_2_43701b0_1561553656929_461415_25920</outgoing>
            <outgoing>_19_0_2_43701b0_1561553656930_496084_25927</outgoing>
        </task>
        <subProcess triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Prepare for custody" id="_19_0_2_43701b0_1561553656924_296032_25902">
            <documentation textFormat="text/plain">Prepare to take custody of the election object. This object may need to be labeled so that it can be uniquely tracked, placed in a transport, or sealed to provide tamper evidence.</documentation>
            <incoming>_19_0_2_43701b0_1561553656929_681711_25917</incoming>
            <outgoing>_19_0_2_43701b0_1561553656929_92236_25918</outgoing>
            <outgoing>_19_0_2_43701b0_1561569238087_566608_26092</outgoing>
        </subProcess>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Add label to object" id="_19_0_2_43701b0_1561553656944_212315_25947">
            <documentation textFormat="text/plain">Objects placed under chain of custody must be uniquely labeled if they don't already have a unique identifier. The identifier should be protected such that it cannot be modified without breaking a seal.</documentation>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Seal object" id="_19_0_2_43701b0_1561553656944_579880_25948">
            <documentation textFormat="text/plain">Seal the object in a transport. The seal should be tamper evident. A lock, for example, is not a valid seal.</documentation>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Place object in transport" id="_19_0_2_43701b0_1561569544438_115810_26118">
            <documentation textFormat="text/plain">Place the object in a transport such that it can be effectively identified and sealed.</documentation>
        </task>
        <parallelGateway name="" id="_19_0_2_43701b0_1561553656925_268055_25903" gatewayDirection="Unspecified">
            <incoming>_19_0_2_43701b0_1561553656929_411376_25919</incoming>
            <incoming>_19_0_2_43701b0_1561553656929_461415_25920</incoming>
            <outgoing>_19_0_2_43701b0_1561553656930_426085_25921</outgoing>
        </parallelGateway>
        <parallelGateway name="" id="_19_0_2_43701b0_1561553656925_858665_25904" gatewayDirection="Unspecified">
            <incoming>_19_0_2_43701b0_1561553656930_426085_25921</incoming>
            <outgoing>_19_0_2_43701b0_1561553656930_626568_25922</outgoing>
            <outgoing>_19_0_2_43701b0_1561553656930_603335_25929</outgoing>
            <outgoing>_19_0_2_43701b0_1561556369367_161480_26004</outgoing>
        </parallelGateway>
        <intermediateCatchEvent name="Custodian Change" id="_19_0_2_43701b0_1561553656925_86123_25905">
            <incoming>_19_0_2_43701b0_1561553656930_626568_25922</incoming>
            <outgoing>_19_0_2_43701b0_1561553656930_594776_25928</outgoing>
            <messageEventDefinition id="_19_0_2_43701b0_1561553656925_86123_25905_msgDef"/>
        </intermediateCatchEvent>
        <endEvent name="Chain of Custody Maintained" id="_19_0_2_43701b0_1561553656926_464428_25906">
            <incoming>_19_0_2_43701b0_1561553656930_364137_25923</incoming>
            <incoming>_19_0_2_43701b0_1561571431511_215005_26418</incoming>
        </endEvent>
        <startEvent isInterrupting="true" name="Object deployed" id="_19_0_2_43701b0_1561553656926_536236_25907">
            <outgoing>_19_0_2_43701b0_1561553656930_480031_25924</outgoing>
        </startEvent>
        <intermediateCatchEvent name="Transfer Custody" id="_19_0_2_43701b0_1561553656926_158422_25908">
            <outgoing>_19_0_2_43701b0_1561553656930_550947_25925</outgoing>
            <messageEventDefinition id="_19_0_2_43701b0_1561553656926_158422_25908_msgDef"/>
        </intermediateCatchEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Transfer Custody" id="_19_0_2_43701b0_1561553656926_582788_25909">
            <incoming>_19_0_2_43701b0_1561553656930_638104_25926</incoming>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Inspect object seal" id="_19_0_2_43701b0_1561553656927_589428_25910">
            <documentation textFormat="text/plain">Inspect the seals and labels on the object and record any discrepancy in the chain of custody log.</documentation>
            <incoming>_19_0_2_43701b0_1561553656930_594776_25928</incoming>
