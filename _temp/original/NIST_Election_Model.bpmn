                <flowNodeRef>_18_5_1_11940316_1502387411863_221229_38610</flowNodeRef>
            </lane>
        </laneSet>
        <subProcess triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Try to Lay Out Ballot" id="_18_5_1_11940316_1502385374226_704371_38499">
            <documentation textFormat="text/plain">Try to select the contests and options to appear on a ballot and apply business rules determining their order and location.</documentation>
            <incoming>_18_5_1_11940316_1502385707076_820428_38568</incoming>
            <outgoing>_18_5_1_11940316_1502387411922_630601_38614</outgoing>
