        </endEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Update voter record with ballot package received" id="_18_5_1_11940316_1501694839211_404264_26130">
            <documentation textFormat="text/plain">Update the voter record to indicate that the ballot package has been received by the election jurisdiction.</documentation>
            <incoming>_18_5_1_11940316_1501694839269_483129_26138</incoming>
            <incoming>_18_5_1_11940316_1501694966938_411733_26212</incoming>
