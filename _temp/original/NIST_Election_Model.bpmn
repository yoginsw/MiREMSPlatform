    <process isClosed="false" isExecutable="false" name="Prepare Voting Devices" id="_18_5_1_11940316_1500468882115_966786_24545">
        <documentation textFormat="text/plain">Prepare voting devices such that they are ready for election deployment.</documentation>
        <laneSet id="_18_5_1_11940316_1500468882115_966786_24545_laneSet">
            <lane name="Election Jurisdiction" id="_18_5_2_11940316_1504125119653_120111_42576">
                <flowNodeRef>_18_5_1_11940316_1503517554519_155711_61445</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1503517587311_415155_61529</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1503517758950_187844_61640</flowNodeRef>
                <flowNodeRef>_18_5_2_11940316_1504725213239_463343_28458</flowNodeRef>
                <flowNodeRef>_18_5_2_11940316_1505328482261_243011_40516</flowNodeRef>
                <flowNodeRef>_18_5_2_11940316_1505329786506_860539_40649</flowNodeRef>
            </lane>
        </laneSet>
        <startEvent isInterrupting="true" name="" id="_18_5_1_11940316_1503517554519_155711_61445">
            <outgoing>_18_5_1_11940316_1503517753746_135541_61631</outgoing>
        </startEvent>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Determine voting machine quantity" id="_18_5_1_11940316_1503517587311_415155_61529">
            <documentation textFormat="text/plain">Determine the number of voting machines that need to be deployed for the election. The quantity is determined by a mixture of factors, such as the polling location configuration, systems used, and expected turnout.</documentation>
            <incoming>_18_5_1_11940316_1503517753746_135541_61631</incoming>
            <outgoing>_18_5_2_11940316_1504726256858_558010_28594</outgoing>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Write media devices" id="_18_5_1_11940316_1503517758950_187844_61640">
            <documentation textFormat="text/plain">Write the media devices that when connected to a voting device, determine its configuration. Media may be specifically written for use in a particular poll location configuration.</documentation>
            <incoming>_18_5_1_11940316_1503517759093_727015_61648</incoming>
            <incoming>_18_5_1_11940316_1503518319029_760747_61702</incoming>
            <outgoing>_18_5_2_11940316_1505328488480_529621_40532</outgoing>
        </task>
        <dataObjectReference name="EMS Configurations" id="_18_5_1_11940316_1503518306021_516837_61677">
            <outgoing>_18_5_1_11940316_1503518319029_760747_61702</outgoing>
        </dataObjectReference>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Allocate voting machines" id="_18_5_2_11940316_1504725213239_463343_28458">
            <documentation textFormat="text/plain">Identify the actual equipment used during the election, including spares. A minimum number of machines allocated per geography is often specified by law or policy.</documentation>
            <incoming>_18_5_2_11940316_1504726264742_176612_28606</incoming>
            <outgoing>_18_5_2_11940316_1505328492752_466108_40541</outgoing>
            <outgoing>_18_5_2_11940316_1506692734565_599733_30529</outgoing>
        </task>
        <parallelGateway name="" id="_18_5_2_11940316_1504726255879_747597_28586" gatewayDirection="Unspecified">
            <incoming>_18_5_2_11940316_1504726256858_558010_28594</incoming>
            <outgoing>_18_5_1_11940316_1503517759093_727015_61648</outgoing>
            <outgoing>_18_5_2_11940316_1504726264742_176612_28606</outgoing>
        </parallelGateway>
        <endEvent name="Electronic Voting Devices Prepared" id="_18_5_2_11940316_1505328482261_243011_40516">
            <incoming>_18_5_2_11940316_1505328482330_459918_40520</incoming>
        </endEvent>
