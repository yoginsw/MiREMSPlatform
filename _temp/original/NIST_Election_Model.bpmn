        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Split or combine address ranges as needed" id="_18_5_3_43701b0_1517865584656_82931_62797">
            <documentation textFormat="text/plain">Split or combine address ranges such that a given address range is associated with exactly one precinct-split.</documentation>
            <incoming>_18_5_3_43701b0_1517440290973_157019_30867</incoming>
            <outgoing>_18_5_3_43701b0_1517865602583_406066_62826</outgoing>
