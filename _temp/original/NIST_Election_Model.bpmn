    <process isClosed="false" isExecutable="false" name="Open Polling Location" id="_18_5_1_11940316_1500466962610_540406_23669">
        <documentation textFormat="text/plain">Open the polling location so that voters may begin voting.</documentation>
        <laneSet id="_18_5_1_11940316_1500486264582_842860_30271_Ref-1_laneSet">
            <lane name="Poll Worker" partitionElementRef="_18_5_1_11940316_1498828652641_269229_23308" id="_18_5_1_11940316_1500486264582_842860_30271">
                <flowNodeRef>_18_5_1_11940316_1500486684760_477056_30381</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1500486840501_928682_30489</flowNodeRef>
                <flowNodeRef>_18_5_2_43701b0_1510172628594_934116_31588</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1500484369558_377245_30107</flowNodeRef>
                <flowNodeRef>_18_5_2_43701b0_1510172051498_688756_31467</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1500484413699_537853_30144</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1500483928854_94691_29960</flowNodeRef>
                <flowNodeRef>_18_5_1_11940316_1500483888954_41634_29908</flowNodeRef>
                <flowNodeRef>_18_5_2_43701b0_1511354729579_921455_29818</flowNodeRef>
            </lane>
        </laneSet>
        <laneSet id="_18_5_1_11940316_1500483595861_801304_29591_Ref-1_laneSet">
            <lane name="Poll Worker" partitionElementRef="_18_5_1_11940316_1498828652641_269229_23308" id="_18_5_1_11940316_1500483595861_801304_29591"/>
        </laneSet>
        <laneSet id="_18_5_1_11940316_1500483586611_446885_29560_Ref-1_laneSet">
            <lane name="Poll Worker" partitionElementRef="_18_5_1_11940316_1498999818037_96552_21933" id="_18_5_1_11940316_1500483586611_446885_29560"/>
        </laneSet>
        <startEvent isInterrupting="true" name="Time to arrive at polling location" id="_18_5_1_11940316_1500486684760_477056_30381">
            <outgoing>_18_5_1_11940316_1500486688296_943645_30396</outgoing>
            <timerEventDefinition id="_18_5_1_11940316_1500486684760_477056_30381_Ref-1"/>
        </startEvent>
        <endEvent name="Polling Location Opened" id="_18_5_1_11940316_1500486840501_928682_30489">
            <incoming>_18_5_1_11940316_1500486840535_626877_30494</incoming>
        </endEvent>
        <adHocSubProcess cancelRemainingInstances="true" ordering="Parallel" triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Check equipment" id="_18_5_2_43701b0_1510172628594_934116_31588">
            <documentation textFormat="text/plain">Check that the equipment is ready for use. The poll workers may also inspect the equipment for damage or tampering.</documentation>
            <incoming>_18_5_2_43701b0_1510172629830_602494_31609</incoming>
            <outgoing>_18_5_2_43701b0_1510172052539_986327_31480</outgoing>
            <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-1"/>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Validate no ballots cast" id="_18_5_2_43701b0_1510172316060_368685_31507">
                <documentation textFormat="text/plain">Ensure that no ballots have been cast, such as by checking the ballot boxes, or machine totals.</documentation>
                <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-2"/>
            </task>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Ensure equipment integrity " id="_18_5_2_43701b0_1510172414069_411660_31548">
                <documentation textFormat="text/plain">Ensure the equipment has not been tampered with.</documentation>
                <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-3"/>
            </task>
        </adHocSubProcess>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Set up voting stations, materials, and signage" id="_18_5_1_11940316_1500484369558_377245_30107">
            <documentation textFormat="text/plain">Some setup may be done in the days leading up to voting. Other setup tasks may be done immediately before voting. Because voting locations are often rented facilities, the space may need to be modified to become conducive to voting.</documentation>
            <incoming>_18_5_1_11940316_1500484369621_245455_30116</incoming>
            <outgoing>_18_5_1_11940316_1500484431985_584337_30182</outgoing>
            <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-4"/>
        </task>
        <intermediateCatchEvent name="Time to Open Polling Location" id="_18_5_2_43701b0_1510172051498_688756_31467">
            <incoming>_18_5_2_43701b0_1510172052539_986327_31480</incoming>
            <outgoing>_18_5_1_11940316_1500486840535_626877_30494</outgoing>
            <timerEventDefinition id="_18_5_2_43701b0_1510172051498_688756_31467_Ref-1"/>
        </intermediateCatchEvent>
        <adHocSubProcess cancelRemainingInstances="true" ordering="Parallel" triggeredByEvent="false" isForCompensation="false" startQuantity="1" completionQuantity="1" name="Setup activities" id="_18_5_1_11940316_1500484413699_537853_30144">
            <documentation textFormat="text/plain">Perform setup activities according to the election jurisdiction's policies and procedures.</documentation>
            <incoming>_18_5_1_11940316_1500484431985_584337_30182</incoming>
            <outgoing>_18_5_2_43701b0_1510172629830_602494_31609</outgoing>
            <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-5"/>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Setup e-poll books" id="_18_5_1_11940316_1500484521042_620887_30194">
                <documentation textFormat="text/plain">Unpack and setup the electronic poll books according to a predetermined configuration, for example connecting a tablet to a printer. There may be certain poll opening tasks as well, such as logging into the e-poll book software.
 
</documentation>
                <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-6"/>
                <resourceRole name="" id="_18_5_2_11940316_1504815099805_538730_31251_Ref-1"/>
            </task>
            <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Set up voting devices" id="_18_5_1_11940316_1500484547517_471964_30224">
                <documentation textFormat="text/plain">Set up the voting devices, such as turning the devices on, and performing poll opening tasks.</documentation>
                <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-7"/>
            </task>
            <completionCondition xsi:type="tFormalExpression">Applicable tasks completed</completionCondition>
        </adHocSubProcess>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Inventory equipment and materials" id="_18_5_1_11940316_1500483928854_94691_29960">
            <documentation textFormat="text/plain">Ensure all the required materials for a polling location are accounted for. </documentation>
            <incoming>_18_5_1_11940316_1500483928925_843238_29970</incoming>
            <outgoing>_18_5_1_11940316_1500484369621_245455_30116</outgoing>
            <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-8"/>
        </task>
        <task isForCompensation="false" startQuantity="1" completionQuantity="1" name="Access polling location facility" id="_18_5_1_11940316_1500483888954_41634_29908">
            <documentation textFormat="text/plain">Gain access to the polling location.</documentation>
            <incoming>_18_5_1_11940316_1500486688296_943645_30396</incoming>
            <outgoing>_18_5_1_11940316_1500483928925_843238_29970</outgoing>
            <resourceRole name="" id="_18_5_1_11940316_1500483889173_90615_29922_Ref-9"/>
        </task>
